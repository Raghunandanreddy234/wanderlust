<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-3 show-card">

 
<h3>Listing Details :</h3>

<div class="card col-8">
  <img 
    src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image" />

  <div class="card-body">
    <p class="card-text">
      <b><%= listing.title %></b> <br />
      <%= listing.description %> <br />
      ₹ <%= listing.price %> <br />
        <%= listing.location %> <br />
        <%= listing.country %>
    </p>
  </div>
</div>

<br />

<div class="btns">

  <a href="/listings/<%= listing._id %>/edit"  class="btn btn-dark edit-btn  col-2.5  mt-3">Edit</a>
<br /> <br />

<form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
  <button  class="btn btn-dark offset-3 mt-3">Delete</button>
</form>
</div>
</div>
</div>

