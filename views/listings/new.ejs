<% layout("/layouts/boilerplate") %>
  <body>
   <br />  <br /> 
    <h3 class>Create a New Listing</h3>
     <div class="co1-8 offset-2">
   <form method="POST" action="/listings" novalidate class="needs-validation">
  <div class="mb-3">
    <label for="title" class="form-label"><b><i>Title:</i></b></label>
    <input
      name="listing[title]"
      placeholder="Add a catchy title"
      type="text"
      class="form-control"
      required
    />
    <div class="valid-feedback">Title looks good!</div>
  </div>

  <div class="mb-3">
    <label for="description" class="form-label"><b><i>Description:</i></b></label>
    <textarea
      name="listing[description]"
      class="form-control"
      required
    ></textarea>
    <div class="invalid-feedback">write a short description!</div>
  </div>
    
       
      <div  class="mb-3">
         <label for="image" class="form-label"><b><i>Image:</i></b></label>
      <input
  name="listing[image][url]"
  placeholder="Enter image URL/link"
  class="form-control"
  type="text" 
/>
      </div>
      
       <div class="row">
        <div  class="mb-3 col-md-4">
        <label for="price" class="form-label"><b><i>Price:</i></b></label>
      <input name="listing[price]" 
      placeholder="1200" 
      class="form-control"
      type="text" required/>
       <div class="invalid-feedback">Please enter a valid price</div>
       </div>
     
      
        <div  class="mb-3 col-md-8">
           <label for="country" class="form-label"><b><i>Country:</i></b></label>
      <input name="listing[country]" 
      placeholder="India" 
      class="form-control"
      type="text" required />
       <div class="invalid-feedback">please enter   country name!</div>
      </div>
          <br /> <br />

       <div  class="mb-3">
         <label for="location" class="form-label"><b><i>Location:</i></b></label>
      <input
        name="listing[location]"
        placeholder="Poidicherry, Tamilnadu"
        class="form-control"
        type="text" required
      />
       <div class="invalid-feedback">please enter valid  location!</div>
  </div>
       </div>
      <br /><br />
      <button class="btn btn-dark add-btn"  >Add</button>
      <br /> <br />  
    </form>
    </div>
 